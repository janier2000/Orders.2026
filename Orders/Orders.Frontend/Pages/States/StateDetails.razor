@page "/states/details/{StateId:int}"

<h3>Detalle País</h3>

@if (state is null)
{
    <Loading />
}
else
{
    <h3>@state.Name</h3>

    <a class="btn btn-primary" href="/cities/create/@StateId">Nuevo Ciudad</a>
    <a class="btn btn-success" href="/countries/details/@state.CountryId">Regresar</a>

    <h4>Ciudades</h4>
    @*  <GenericList MyList="state.Cities!.ToList()"> *@
    <GenericList MyList="cities!">
        <Body>
            <Pagination CurrentPage="currentPage"
                        TotalPages="totalPages"
                        SelectedPage="SelectedPageAsync" />
           @*  RecordsNumber="SelectedRecordsNumberAsync" /> *@
         
            <div class="mb-2" style="display: flex; flex-wrap:wrap; align-items: center;">
                <input style="width: 400px;" type="text" class="form-control" id="titulo" placeholder="Buscar ciudad..." @bind-value="Filter" />
                <botton type="button" class="btn btn-outline-primary mx-1" @onclick="ApplyFilterAsync">Filtrar</botton>
                <botton type="button" class="btn btn-outline-danger" @onclick="CleanFilterAsync">Limpiar</botton><botton type="button" class="btn btn-primary mx-1" @onclick="ApplyFilterAsync">Limpiar</botton>
            </div>

            <table class="table table-striped">
                <thead>
                    <tr>
                        <th style="width:90px">Ciudad</th>
                        <th style="width:168px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var city in cities!)
                    {
                        <tr>
                            <td><a href="/states/details/@state.Id">@city.Name</a></td>
                            <td>
                                @* <a class="btn btn-warning btn-sm" @onclick=@(() => ShowModalAsync(state.Id, true))><i class="bi bi-pencil" /> Editar</a> *@
                                <a class="btn btn-warning btn-sm" href="/cities/edit/@city.Id"><i class="bi bi-pencil" /> Editar</a>
                                <button class="btn btn-danger btn-sm" @onclick=@(() => DeleteAsync(city))><i class="bi bi-trash" /> Borrar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </Body>
    </GenericList>
}

