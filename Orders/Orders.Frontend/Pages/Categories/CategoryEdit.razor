@page "/categories/edit/{Id:int}"

<h3>Editar Categoria</h3>

@if (category is null)
{
    <Loading/>
}
else
{
    <FormWithName @ref="categoryForm"
                    Label="Categoría: "
                    Model="category" 
                    OnValidSubmit="EditAsync" 
                    ReturnAction="Return" />
    @* <CategoryForm @ref="categoryForm" Category="category" OnValidSubmit="EditAsync" ReturnAction="Return" /> *@
} 